{
  "name": "musubi-ichiba",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "preview_urls": false,
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "musubi-ichiba-db",
      "database_id": "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
    }
  ]
}
